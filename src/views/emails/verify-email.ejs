<!DOCTYPE html>
<html lang="<%= locale %>">
<head><meta charset="utf-8"></head>
<body style="font-family: sans-serif; line-height: 1.5; color: #111;">
  <p><%= t('emails.verify-email.greeting', { name }) %>,</p>
  <p><%= t('emails.verify-email.body', { siteName }) %></p>
  <p><a href="<%= verifyUrl %>" style="display:inline-block;padding:0.6em 1.2em;background:#3b82f6;color:#fff;text-decoration:none;border-radius:4px;"><%= t('emails.verify-email.linkText') %></a></p>
  <p style="word-break:break-all; color:#666; font-size:0.9em;"><%= verifyUrl %></p>
  <p style="color:#999; font-size:0.85em;"><%= t('emails.verify-email.ignore') %></p>
</body>
</html>
