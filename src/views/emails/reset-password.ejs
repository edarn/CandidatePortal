<!DOCTYPE html>
<html lang="<%= locale %>">
<head><meta charset="utf-8"></head>
<body style="font-family: sans-serif; line-height: 1.5; color: #111;">
  <p><%= t('emails.reset-password.greeting') %>,</p>
  <p><%= t('emails.reset-password.body') %></p>
  <p><a href="<%= resetUrl %>" style="display:inline-block;padding:0.6em 1.2em;background:#3b82f6;color:#fff;text-decoration:none;border-radius:4px;"><%= t('emails.reset-password.linkText') %></a></p>
  <p style="word-break:break-all; color:#666; font-size:0.9em;"><%= resetUrl %></p>
  <p style="color:#999; font-size:0.85em;"><%= t('emails.reset-password.ignore') %></p>
</body>
</html>
