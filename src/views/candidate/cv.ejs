<%- include('../partials/head', { pageTitle: t('me.cv.title') }) %>
<p style="margin-bottom: 1rem;"><a href="/me">&larr; <%= t('common.back') %></a></p>

<section>
  <h1><%= t('me.cv.title') %></h1>

  <% if (candidate.cv_filename) { %>
    <p><strong><%= t('me.cv.current') %>:</strong> <%= candidate.cv_original_name %></p>
    <p class="muted" style="font-size: 0.88rem;"><%= t('me.cv.uploadedAt') %>: <%= candidate.cv_uploaded_at %></p>
    <div class="actions-row" style="margin-top: 0.75rem;">
      <a href="/me/cv/download" role="button" class="secondary"><%= t('common.download') %></a>
      <form method="post" action="/me/cv/delete" class="inline-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="secondary outline"><%= t('me.cv.delete') %></button>
      </form>
    </div>
  <% } else { %>
    <p class="muted"><%= t('me.cv.noFile') %></p>
  <% } %>
</section>

<section>
  <h3><%= t('me.cv.upload') %></h3>
  <form method="post" action="/me/cv" enctype="multipart/form-data" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>
      <input type="file" name="cv" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required>
      <small><%= t('me.cv.uploadHint') %></small>
    </label>
    <button type="submit"><%= t('common.upload') %></button>
  </form>
</section>
<%- include('../partials/foot') %>
