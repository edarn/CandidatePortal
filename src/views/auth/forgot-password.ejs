<%- include('../partials/head', { pageTitle: t('auth.forgot.title') }) %>
<section>
  <h1><%= t('auth.forgot.title') %></h1>
  <% if (sent) { %>
    <div class="flash success"><%= t('auth.forgot.sent') %></div>
    <p><a href="/login" role="button" class="secondary"><%= t('auth.login.title') %></a></p>
  <% } else { %>
    <p><%= t('auth.forgot.instructions') %></p>
    <form method="post" action="/forgot-password" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>
        <%= t('fields.email') %>
        <input type="email" name="email" value="<%= values.email || '' %>" required>
        <% if (errors.email) { %><span class="field-error"><%= t(errors.email) %></span><% } %>
      </label>
      <button type="submit"><%= t('auth.forgot.submit') %></button>
    </form>
  <% } %>
</section>
<%- include('../partials/foot') %>
