<%- include('../partials/head', { pageTitle: t('auth.login.title') }) %>
<section>
  <h1><%= t('auth.login.title') %></h1>
  <% if (errors._form) { %>
    <div class="flash error"><%= t(errors._form) %></div>
  <% } %>
  <form method="post" action="/login" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>
      <%= t('fields.email') %>
      <input type="email" name="email" value="<%= values.email || '' %>" required>
    </label>
    <label>
      <%= t('fields.password') %>
      <input type="password" name="password" required>
    </label>
    <button type="submit"><%= t('auth.login.submit') %></button>
  </form>
  <p><a href="/forgot-password"><%= t('auth.login.forgotPassword') %></a></p>
  <p><%= t('auth.login.noAccount') %> <a href="/register"><%= t('auth.login.registerLink') %></a></p>
</section>
<%- include('../partials/foot') %>
