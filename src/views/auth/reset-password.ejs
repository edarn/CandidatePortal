<%- include('../partials/head', { pageTitle: t('auth.reset.title') }) %>
<section class="auth-card">
  <h1><%= t('auth.reset.title') %></h1>
  <form method="post" action="/reset-password" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="token" value="<%= token %>">
    <label>
      <%= t('fields.newPassword') %>
      <input type="password" name="password" required minlength="10" autofocus>
      <% if (errors.password) { %><span class="field-error"><%= t(errors.password) %></span><% } %>
    </label>
    <button type="submit"><%= t('auth.reset.submit') %></button>
  </form>
</section>
<%- include('../partials/foot') %>
