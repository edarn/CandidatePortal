<%- include('../partials/head', { pageTitle: t('admin.list.title') }) %>

<div class="stats-banner">
  <div class="stat-card stat-indigo">
    <div class="stat-icon">👥</div>
    <div class="stat-value"><%= stats.total_candidates %></div>
    <div class="stat-label"><%= t('admin.stats.candidates') %></div>
  </div>
  <div class="stat-card stat-emerald">
    <div class="stat-icon">✓</div>
    <div class="stat-value"><%= stats.verified_count %></div>
    <div class="stat-label"><%= t('admin.stats.verified') %></div>
  </div>
  <div class="stat-card stat-amber">
    <div class="stat-icon">🏷️</div>
    <div class="stat-value"><%= stats.tags_count %></div>
    <div class="stat-label"><%= t('admin.stats.tags') %></div>
  </div>
  <div class="stat-card stat-pink">
    <div class="stat-icon">✨</div>
    <div class="stat-value"><%= stats.new_this_week %></div>
    <div class="stat-label"><%= t('admin.stats.newThisWeek') %></div>
  </div>
</div>

<section>
  <header class="list-header">
    <h1><%= t('admin.list.title') %> <span class="muted" id="candidates-count">(<%= total %>)</span></h1>
    <div class="actions-row">
      <a href="/admin/export.csv<%= csvQuery ? '?' + csvQuery : '' %>" role="button" class="secondary"><%= t('admin.exportCsv') %></a>
      <a href="/admin/tags" role="button" class="secondary outline"><%= t('admin.tags.title') %></a>
    </div>
  </header>

  <form id="admin-filter-form" method="get" action="/admin" class="filter-bar" autocomplete="off">
    <input
      type="search"
      name="q"
      value="<%= currentParams.q || '' %>"
      placeholder="<%= t('admin.list.search') %>"
      aria-label="<%= t('admin.list.search') %>"
    >
    <select name="tag" aria-label="<%= t('admin.list.filterTag') %>">
      <option value=""><%= t('admin.list.filterTag') %>: <%= t('common.all') %></option>
      <% allTags.forEach(function(tag) { %>
        <option value="<%= tag.id %>" <%= String(tag.id) === String(currentParams.tag) ? 'selected' : '' %>><%= tag.name %></option>
      <% }); %>
    </select>
    <select name="sort" aria-label="<%= t('admin.list.sort') %>">
      <option value="date_desc" <%= currentParams.sort === 'date_desc' || !currentParams.sort ? 'selected' : '' %>><%= t('admin.list.sortDateDesc') %></option>
      <option value="date_asc" <%= currentParams.sort === 'date_asc' ? 'selected' : '' %>><%= t('admin.list.sortDateAsc') %></option>
      <option value="name" <%= currentParams.sort === 'name' ? 'selected' : '' %>><%= t('admin.list.sortNameAsc') %></option>
      <option value="name_desc" <%= currentParams.sort === 'name_desc' ? 'selected' : '' %>><%= t('admin.list.sortNameDesc') %></option>
    </select>
  </form>

  <div id="candidates-table-container">
    <%- include('list-fragment', { rows, total, page, totalPages, currentParams }) %>
  </div>
</section>

<script src="/admin-search.js"></script>
<%- include('../partials/foot') %>
