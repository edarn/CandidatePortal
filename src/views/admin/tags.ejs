<%- include('../partials/head', { pageTitle: t('admin.tags.title') }) %>
<section>
  <p><a href="/admin">&larr; <%= t('common.back') %></a></p>
  <h1><%= t('admin.tags.title') %></h1>

  <article>
    <h3><%= t('admin.tags.create') %></h3>
    <form method="post" action="/admin/tags">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div style="display:flex; gap:1rem;">
        <label style="flex:1;"><%= t('fields.tagName') %><input type="text" name="name" required></label>
        <label style="flex:1;"><%= t('fields.tagColor') %><input type="text" name="color" placeholder="#3b82f6"></label>
      </div>
      <button type="submit"><%= t('common.create') %></button>
    </form>
  </article>

  <% if (tags.length === 0) { %>
    <p class="muted"><%= t('admin.tags.noTags') %></p>
  <% } else { %>
    <table>
      <thead><tr>
        <th><%= t('fields.tagName') %></th>
        <th><%= t('fields.tagColor') %></th>
        <th></th>
        <th><%= t('common.actions') %></th>
      </tr></thead>
      <tbody>
      <% tags.forEach(function(tag) { %>
        <tr>
          <td colspan="3">
            <form method="post" action="/admin/tags/<%= tag.id %>" class="inline-form" style="display:flex; gap:0.5rem; align-items:center;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="text" name="name" value="<%= tag.name %>" required style="margin:0; flex:1;">
              <input type="text" name="color" value="<%= tag.color || '' %>" style="margin:0; width:120px;">
              <span class="tag-pill" style="background:<%= tag.color || '#6b7280' %>"><%= tag.name %></span>
              <button type="submit" class="secondary" style="margin:0;"><%= t('common.save') %></button>
            </form>
          </td>
          <td>
            <form method="post" action="/admin/tags/<%= tag.id %>/delete" class="inline-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="secondary outline" style="margin:0;"><%= t('common.delete') %></button>
            </form>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  <% } %>
</section>
<%- include('../partials/foot') %>
