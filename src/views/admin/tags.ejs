<%- include('../partials/head', { pageTitle: t('admin.tags.title') }) %>
<p style="margin-bottom: 1rem;"><a href="/admin">&larr; <%= t('common.back') %></a></p>
<h1 style="margin-bottom: 1rem;"><%= t('admin.tags.title') %></h1>

<article>
  <h3 style="margin-top: 0;"><%= t('admin.tags.create') %></h3>
  <form method="post" action="/admin/tags" class="tag-form-row">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="text" name="name" placeholder="<%= t('fields.tagName') %>" required>
    <input type="color" name="color" value="#6366f1" aria-label="<%= t('fields.tagColor') %>">
    <button type="submit"><%= t('common.create') %></button>
  </form>
</article>

<article>
  <% if (tags.length === 0) { %>
    <p class="muted"><%= t('admin.tags.noTags') %></p>
  <% } else { %>
    <div class="tags-list">
      <% tags.forEach(function(tag) { %>
        <div class="tag-row">
          <span class="tag-pill" style="background: <%= tag.color || '#6b7280' %>"><%= tag.name %></span>
          <form method="post" action="/admin/tags/<%= tag.id %>" class="tag-form-row tag-edit-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="text" name="name" value="<%= tag.name %>" required>
            <input type="color" name="color" value="<%= tag.color || '#6b7280' %>" aria-label="<%= t('fields.tagColor') %>">
            <button type="submit" class="secondary"><%= t('common.save') %></button>
          </form>
          <form method="post" action="/admin/tags/<%= tag.id %>/delete" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="secondary outline"><%= t('common.delete') %></button>
          </form>
        </div>
      <% }); %>
    </div>
  <% } %>
</article>
<%- include('../partials/foot') %>
