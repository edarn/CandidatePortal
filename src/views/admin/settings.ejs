<%- include('../partials/head', { pageTitle: t('admin.settings.title') }) %>
<section>
  <p><a href="/admin">&larr; <%= t('common.back') %></a></p>
  <h1><%= t('admin.settings.title') %></h1>

  <article>
    <h3><%= t('admin.settings.logo') %></h3>
    <% if (logoFilename) { %>
      <p><img src="/branding/logo" style="max-height:60px; border:1px solid #ddd; padding:0.5rem; background:#fff;"></p>
      <form method="post" action="/admin/settings/logo/delete" class="inline-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="secondary outline"><%= t('admin.settings.logoDelete') %></button>
      </form>
    <% } else { %>
      <p class="muted"><%= t('admin.settings.logoNone') %></p>
    <% } %>

    <form method="post" action="/admin/settings/logo" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>
        <%= t('admin.settings.logoUpload') %>
        <input type="file" name="logo" accept="image/png,image/jpeg,image/svg+xml" required>
        <small><%= t('admin.settings.logoHint') %></small>
      </label>
      <button type="submit"><%= t('common.upload') %></button>
    </form>
  </article>

  <article>
    <h3><%= t('admin.settings.backup') %></h3>
    <p class="muted"><%= t('admin.settings.backupHint') %></p>
    <p><a href="/admin/backup" role="button"><%= t('admin.settings.backupNow') %></a></p>
  </article>
</section>
<%- include('../partials/foot') %>
