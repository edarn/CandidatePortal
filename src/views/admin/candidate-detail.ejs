<%- include('../partials/head', { pageTitle: candidate.full_name }) %>
<section>
  <p><a href="/admin">&larr; <%= t('common.back') %></a></p>
  <h1><%= candidate.full_name %></h1>

  <article>
    <h3><%= t('me.title') %></h3>
    <p>
      <strong><%= t('fields.email') %>:</strong> <%= candidate.email %>
      <% if (candidate.email_verified_at) { %>
        <span class="tag-pill" style="background:#10b981;">✓ <%= t('admin.list.verified') %></span>
      <% } else { %>
        <span class="tag-pill" style="background:#f59e0b;"><%= t('admin.list.notVerified') %></span>
      <% } %>
    </p>
    <p><strong><%= t('fields.phone') %>:</strong> <%= candidate.phone %></p>
    <% if (candidate.linkedin_url) { %>
      <p><strong><%= t('fields.linkedin') %>:</strong> <a href="<%= candidate.linkedin_url %>" target="_blank" rel="noopener"><%= candidate.linkedin_url %></a></p>
    <% } %>
    <% if (candidate.current_role) { %><p><strong><%= t('fields.currentRole') %>:</strong> <%= candidate.current_role %></p><% } %>
    <% if (candidate.current_company) { %><p><strong><%= t('fields.currentCompany') %>:</strong> <%= candidate.current_company %></p><% } %>
    <% if (candidate.location) { %><p><strong><%= t('fields.location') %>:</strong> <%= candidate.location %></p><% } %>
    <% if (candidate.summary) { %>
      <p><strong><%= t('fields.summary') %>:</strong></p>
      <p style="white-space: pre-wrap;"><%= candidate.summary %></p>
    <% } %>
    <p class="muted"><small><%= t('admin.candidate.registeredAt') %>: <%= candidate.created_at %></small></p>
  </article>

  <article>
    <h3><%= t('admin.candidate.tags') %></h3>
    <% if (allTags.length === 0) { %>
      <p class="muted"><%= t('admin.tags.noTags') %> <a href="/admin/tags"><%= t('admin.tags.create') %></a></p>
    <% } else { %>
      <form method="post" action="/admin/candidate/<%= candidate.user_id %>/tags">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% allTags.forEach(function(tag) { %>
          <label style="display:inline-flex; align-items:center; gap:0.4em; margin-right:1em; margin-bottom:0.4em;">
            <input type="checkbox" name="tag_ids" value="<%= tag.id %>" <%= currentTagIds.has(tag.id) ? 'checked' : '' %>>
            <span class="tag-pill" style="background:<%= tag.color || '#6b7280' %>"><%= tag.name %></span>
          </label>
        <% }); %>
        <p><button type="submit" class="secondary"><%= t('common.save') %></button></p>
      </form>
    <% } %>
  </article>

  <article>
    <h3><%= t('admin.candidate.notes') %></h3>
    <% notes.forEach(function(note) { %>
      <div style="border-left: 3px solid #3b82f6; padding: 0.5rem 1rem; margin-bottom: 0.75rem; background: #f3f4f6;">
        <% if (note.met_at_location || note.met_at_date) { %>
          <p class="muted" style="margin:0;"><small>
            <% if (note.met_at_date) { %><%= note.met_at_date %><% } %>
            <% if (note.met_at_location) { %> &mdash; <%= note.met_at_location %><% } %>
          </small></p>
        <% } %>
        <p style="white-space: pre-wrap; margin: 0.25rem 0;"><%= note.note_text %></p>
        <p class="muted" style="margin:0;"><small>
          <%= note.created_at %>
          &nbsp;
          <form method="post" action="/admin/notes/<%= note.id %>/delete" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="secondary outline" style="font-size:0.8em; padding:0.1em 0.5em; margin:0;"><%= t('common.delete') %></button>
          </form>
        </small></p>
      </div>
    <% }); %>

    <h4><%= t('admin.candidate.addNote') %></h4>
    <form method="post" action="/admin/candidate/<%= candidate.user_id %>/notes">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div style="display:flex; gap:1rem;">
        <label style="flex:1;"><%= t('admin.candidate.metAt') %><input type="text" name="met_at_location"></label>
        <label style="flex:1;"><%= t('admin.candidate.metDate') %><input type="date" name="met_at_date"></label>
      </div>
      <label><%= t('admin.candidate.noteText') %><textarea name="note_text" rows="3" required></textarea></label>
      <button type="submit"><%= t('common.create') %></button>
    </form>
  </article>

  <article>
    <h3>CV</h3>
    <% if (candidate.cv_filename) { %>
      <p><strong><%= candidate.cv_original_name %></strong> &middot; <span class="muted"><%= candidate.cv_uploaded_at %></span></p>
      <p>
        <a href="/admin/candidate/<%= candidate.user_id %>/cv?download=1" role="button" class="secondary"><%= t('admin.candidate.downloadCv') %></a>
      </p>
      <% if (candidate.cv_mime_type === 'application/pdf') { %>
        <iframe class="cv-preview" src="/admin/candidate/<%= candidate.user_id %>/cv" title="CV preview"></iframe>
      <% } else { %>
        <p class="muted"><%= t('admin.list.previewNotAvailable') %></p>
      <% } %>
    <% } else { %>
      <p class="muted"><%= t('admin.candidate.noCv') %></p>
    <% } %>
  </article>

  <article>
    <h3 class="danger"><%= t('admin.candidate.deleteCandidate') %></h3>
    <form method="post" action="/admin/candidate/<%= candidate.user_id %>/delete"
          onsubmit="return confirm('<%= t('admin.candidate.deleteConfirm') %>');">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="button-danger"><%= t('admin.candidate.deleteCandidate') %></button>
    </form>
  </article>
</section>
<%- include('../partials/foot') %>
