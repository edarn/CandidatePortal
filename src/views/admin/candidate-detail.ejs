<%- include('../partials/head', { pageTitle: candidate.full_name }) %>
<p style="margin-bottom: 1rem;"><a href="/admin">&larr; <%= t('common.back') %></a></p>

<article>
  <h1 style="margin-bottom: 0.5rem;"><%= candidate.full_name %></h1>
  <p style="margin-bottom: 1rem;">
    <% if (candidate.email_verified_at) { %>
      <span class="tag-pill" style="background:#10b981;">✓ <%= t('admin.list.verified') %></span>
    <% } else { %>
      <span class="tag-pill" style="background:#f59e0b;"><%= t('admin.list.notVerified') %></span>
    <% } %>
  </p>

  <dl class="kv">
    <dt><%= t('fields.email') %></dt>
    <dd><a href="mailto:<%= candidate.email %>"><%= candidate.email %></a></dd>

    <dt><%= t('fields.phone') %></dt>
    <dd><%= candidate.phone %></dd>

    <% if (candidate.linkedin_url) { %>
      <dt><%= t('fields.linkedin') %></dt>
      <dd><a href="<%= candidate.linkedin_url %>" target="_blank" rel="noopener"><%= candidate.linkedin_url %></a></dd>
    <% } %>
    <% if (candidate.current_role) { %>
      <dt><%= t('fields.currentRole') %></dt>
      <dd><%= candidate.current_role %></dd>
    <% } %>
    <% if (candidate.current_company) { %>
      <dt><%= t('fields.currentCompany') %></dt>
      <dd><%= candidate.current_company %></dd>
    <% } %>
    <% if (candidate.location) { %>
      <dt><%= t('fields.location') %></dt>
      <dd><%= candidate.location %></dd>
    <% } %>
    <% if (candidate.summary) { %>
      <dt><%= t('fields.summary') %></dt>
      <dd style="white-space: pre-wrap;"><%= candidate.summary %></dd>
    <% } %>

    <dt><%= t('admin.candidate.registeredAt') %></dt>
    <dd class="muted"><%= candidate.created_at %></dd>
  </dl>
</article>

<article>
  <h3><%= t('admin.candidate.tags') %></h3>
  <% if (allTags.length === 0) { %>
    <p class="muted"><%= t('admin.tags.noTags') %> <a href="/admin/tags"><%= t('admin.tags.create') %></a></p>
  <% } else { %>
    <form method="post" action="/admin/candidate/<%= candidate.user_id %>/tags">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="actions-row" style="margin-bottom: 0.75rem;">
        <% allTags.forEach(function(tag) { %>
          <label style="display: inline-flex; align-items: center; gap: 0.4em; font-weight: 400;">
            <input type="checkbox" name="tag_ids" value="<%= tag.id %>" <%= currentTagIds.has(tag.id) ? 'checked' : '' %>>
            <span class="tag-pill" style="background:<%= tag.color || '#6b7280' %>"><%= tag.name %></span>
          </label>
        <% }); %>
      </div>
      <button type="submit" class="secondary"><%= t('common.save') %></button>
    </form>
  <% } %>
</article>

<article>
  <h3><%= t('admin.candidate.notes') %></h3>
  <% notes.forEach(function(note) { %>
    <div class="note">
      <% if (note.met_at_location || note.met_at_date) { %>
        <p class="meta">
          <% if (note.met_at_date) { %><%= note.met_at_date %><% } %>
          <% if (note.met_at_location) { %> &mdash; <%= note.met_at_location %><% } %>
        </p>
      <% } %>
      <p class="body"><%= note.note_text %></p>
      <div class="actions">
        <span class="muted" style="font-size: 0.78rem;"><%= note.created_at %></span>
        <form method="post" action="/admin/notes/<%= note.id %>/delete" class="inline-form" style="margin-left: 0.5rem;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit"><%= t('common.delete') %></button>
        </form>
      </div>
    </div>
  <% }); %>

  <h4 style="margin-top: 1.25rem;"><%= t('admin.candidate.addNote') %></h4>
  <form method="post" action="/admin/candidate/<%= candidate.user_id %>/notes">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="row">
      <label><%= t('admin.candidate.metAt') %><input type="text" name="met_at_location"></label>
      <label><%= t('admin.candidate.metDate') %><input type="date" name="met_at_date"></label>
    </div>
    <label><%= t('admin.candidate.noteText') %><textarea name="note_text" rows="3" required></textarea></label>
    <button type="submit"><%= t('common.create') %></button>
  </form>
</article>

<article>
  <h3>CV</h3>
  <% if (candidate.cv_filename) { %>
    <p>
      <strong><%= candidate.cv_original_name %></strong>
      <span class="muted" style="font-size: 0.88rem;">&middot; <%= candidate.cv_uploaded_at %></span>
    </p>
    <p>
      <a href="/admin/candidate/<%= candidate.user_id %>/cv?download=1" role="button" class="secondary"><%= t('admin.candidate.downloadCv') %></a>
    </p>
    <% if (candidate.cv_mime_type === 'application/pdf') { %>
      <iframe class="cv-preview" src="/admin/candidate/<%= candidate.user_id %>/cv" title="CV preview"></iframe>
    <% } else { %>
      <p class="muted"><%= t('admin.list.previewNotAvailable') %></p>
    <% } %>
  <% } else { %>
    <p class="muted"><%= t('admin.candidate.noCv') %></p>
  <% } %>
</article>

<article>
  <h3 class="danger"><%= t('admin.candidate.deleteCandidate') %></h3>
  <p class="muted"><%= t('admin.candidate.deleteConfirm') %></p>
  <form method="post" action="/admin/candidate/<%= candidate.user_id %>/delete"
        onsubmit="return confirm('<%= t('admin.candidate.deleteConfirm') %>');">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button type="submit" class="button-danger"><%= t('admin.candidate.deleteCandidate') %></button>
  </form>
</article>
<%- include('../partials/foot') %>
