# Copy this file to .env and fill in real values for local development.
# In production (Railway) these are set via the platform's env-var UI.

# ---------------------------------------------------------------
# Core
# ---------------------------------------------------------------
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Used to sign session cookies. Must be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string-of-at-least-32-chars

# ---------------------------------------------------------------
# Storage paths
# (In production on Railway these point under the persistent /data volume.)
# ---------------------------------------------------------------
DATABASE_PATH=./data/database.sqlite
UPLOADS_DIR=./data/uploads
BRANDING_DIR=./data/branding
BACKUPS_DIR=./data/backups

# ---------------------------------------------------------------
# Email (Resend — uses HTTPS API, bypasses SMTP port blocking)
# 1. Sign up at https://resend.com (free tier: 100 emails/day, 3 000/mo).
# 2. Create an API key in the Resend dashboard.
# 3. EMAIL_FROM must be from a verified domain in Resend.
#    For initial testing without a custom domain, use the sandbox sender:
#       EMAIL_FROM=CandidatePortal <onboarding@resend.dev>
#    With the sandbox sender you can ONLY send to the email address that
#    owns the Resend account. Once you verify a domain you can send to
#    anyone.
# ---------------------------------------------------------------
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=CandidatePortal <noreply@yourdomain.com>

# ---------------------------------------------------------------
# Admin bootstrap
# Used once on first startup if no admin user exists in the DB.
# After the admin is created, you can clear these.
# ---------------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# ---------------------------------------------------------------
# Optional: backup to S3-compatible storage
# Leave empty to disable. Works with Backblaze B2, Cloudflare R2, AWS S3, etc.
# ---------------------------------------------------------------
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
BACKUP_S3_REGION=
