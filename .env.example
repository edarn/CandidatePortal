# Copy this file to .env and fill in real values for local development.
# In production (Railway) these are set via the platform's env-var UI.

# ---------------------------------------------------------------
# Core
# ---------------------------------------------------------------
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Used to sign session cookies. Must be at least 32 characters.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string-of-at-least-32-chars

# ---------------------------------------------------------------
# Storage paths
# (In production on Railway these point under the persistent /data volume.)
# ---------------------------------------------------------------
DATABASE_PATH=./data/database.sqlite
UPLOADS_DIR=./data/uploads
BRANDING_DIR=./data/branding
BACKUPS_DIR=./data/backups

# ---------------------------------------------------------------
# SMTP (Gmail)
# 1. Enable 2-Step Verification on the Google account.
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use that 16-char password as SMTP_PASS (no spaces).
# ---------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.address@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=CandidatePortal <your.address@gmail.com>

# ---------------------------------------------------------------
# Admin bootstrap
# Used once on first startup if no admin user exists in the DB.
# After the admin is created, you can clear these.
# ---------------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# ---------------------------------------------------------------
# Optional: backup to S3-compatible storage
# Leave empty to disable. Works with Backblaze B2, Cloudflare R2, AWS S3, etc.
# ---------------------------------------------------------------
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
BACKUP_S3_REGION=
