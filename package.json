{
  "name": "candidate-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Personal portal for collecting candidate contact info and CVs",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "node --env-file=.env --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node --env-file=.env src/db/migrate.js",
    "migrate:prod": "node src/db/migrate.js",
    "create-admin": "node --env-file=.env scripts/create-admin.js",
    "seed-demo": "node --env-file=.env scripts/seed-demo.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "archiver": "^7.0.1",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.7.0",
    "better-sqlite3-session-store": "^0.1.0",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.0.3",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^3.0.3",
    "resend": "^4.0.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "sanitize-html": "^2.13.1",
    "zod": "^3.24.1"
  }
}
